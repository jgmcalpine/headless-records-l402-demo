# Copy to .env (init.sh does this automatically and generates a random
# L402_PROXY_SECRET). Everything here is regtest-only demo configuration —
# no real funds or production credentials belong in this file.

# bitcoind regtest RPC credentials (compose-internal only; not exposed on host)
BITCOIND_RPC_USER=demo
BITCOIND_RPC_PASS=demo

# Shared secret Aperture injects as `x-l402-proxy-secret` on proxied paid
# requests. The API must be started with the same value in L402_PROXY_SECRET.
# init.sh replaces this placeholder with a random value.
L402_PROXY_SECRET=replace-me

# Host port for the Aperture proxy (plain HTTP in this regtest demo).
APERTURE_PORT=8081

# Host port mapped to the buyer lnd node's gRPC (lnget connects here).
BUYER_GRPC_PORT=10010

# Per-request prices in satoshis, one per gated service. Edit these to change
# pricing; re-run ./init.sh (or just re-render + restart aperture) to apply.
SUMMARY_PRICE_SATS=5
TRANSACTIONS_PRICE_SATS=10
